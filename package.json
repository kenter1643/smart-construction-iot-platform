{
  "name": "smart-construction-iot-platform",
  "version": "1.0.0",
  "description": "智慧工地物联网平台",
  "scripts": {
    "dev:frontend": "cd frontend-vue && npm run dev",
    "dev:user-auth": "cd backend/services/user-auth && npm run dev",
    "dev:data-storage": "cd backend/services/data-storage && npm run dev",
    "dev:alerts-notifications": "cd backend/services/alerts-notifications && npm run dev",
    "dev:device-management": "cd backend/services/device-management && npm run dev",
    "build:frontend": "cd frontend-vue && npm run build",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:load": "node tests/load/load-test.js",
    "test": "npm run test:unit && npm run test:integration",
    "deploy:staging": "cd scripts && ./deploy.sh -e staging",
    "deploy:production": "cd scripts && ./deploy.sh -e production",
    "docker:up": "cd docker && docker compose up -d",
    "docker:down": "cd docker && docker compose down",
    "docker:logs": "cd docker && docker compose logs -f"
  },
  "keywords": [
    "iot",
    "smart-construction",
    "construction",
    "real-time",
    "monitoring"
  ],
  "author": "Smart Construction Team",
  "license": "MIT",
  "devDependencies": {
    "axios": "^1.6.5",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "influx": "^5.12.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  }
}
